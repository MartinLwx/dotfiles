{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "permission": {
    "edit": {
      "~/Library/Mobile Documents/iCloud~md~obsidian/Documents/LLMWiki/sources": "deny"
    },
    "bash": {
      "git commit*": "ask",
      "git add*": "ask",
      "git push*": "ask",
      "git pull*": "ask",
      "git merge*": "ask",
      "git rebase*": "ask",
      "git reset*": "ask",
      "git checkout*": "ask",
      "git status": "allow",
      "git log": "allow",
      "git diff": "allow",
      "git branch": "allow",
      "rm *": "ask"
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3:0.6b": {
          "name": "qwen3:0.6b"
        },
        "qwen3:8b": {
          "name": "qwen3:8b"
        }
      }
    }
  }
}
